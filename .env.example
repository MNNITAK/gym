# ─────────────────────────────────────────────────────────────
# KEYSTONE — environment template. Copy to .env and fill in.
# Everything runs inside the Next.js app (apps/dashboard) — no
# separate API server, no Redis.
# ─────────────────────────────────────────────────────────────

# --- Firebase / Firestore (the shared member brain) ---
# Your Firebase project id.
FIREBASE_PROJECT_ID=""

# LOCAL: path to the service-account JSON key (Firebase console → Project
# settings → Service accounts → Generate new private key). Keep it OUT of git.
# Use an ABSOLUTE path — scripts run from different working directories.
GOOGLE_APPLICATION_CREDENTIALS="C:/absolute/path/to/service-account.json"

# VERCEL (serverless has no filesystem): paste the whole key as one env var,
# raw JSON or base64. Generate the value with:
#   node scripts/print-service-account-env.mjs
# FIREBASE_SERVICE_ACCOUNT=""

# --- App wiring ---
NODE_ENV="development"

# --- Auth (staff / coach / owner) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="dev-only-change-me-in-production"
# Password given to the seeded demo coach (coach@demo.gym).
DEMO_COACH_PASSWORD="keystone-demo"

# --- Recurring engine jobs ---
# Shared secret Vercel Cron uses to call POST/GET /api/jobs/run.
# Set this in Vercel and it is sent automatically as a bearer token.
CRON_SECRET=""

# --- LLM provider ---
LLM_PROVIDER="groq"
GROQ_API_KEY=""
GROQ_MODEL_REASONING="llama-3.3-70b-versatile"
GROQ_MODEL_FAST="llama-3.1-8b-instant"

# --- WhatsApp Business Cloud API (optional; simulated when unset) ---
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="keystone-dev-verify"
WHATSAPP_APP_SECRET=""

# --- Firebase web config (browser SDK, for live updates) ---
# Public by design — these identify the project; security comes from Firestore
# rules plus custom-token auth. Copy from Firebase console > Project settings.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
